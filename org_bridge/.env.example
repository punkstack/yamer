# ============================================================
#  Org Bridge — environment configuration
#  Copy this to .env and fill in real values. Never commit .env.
# ============================================================

# --- Slack ---
# From https://api.slack.com/apps → your app → "OAuth & Permissions" → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-...

# From your app → "Basic Information" → "App-Level Tokens" → generate one with
# scope: connections:write (required for Socket Mode)
SLACK_APP_TOKEN=xapp-...

# --- ClickUp ---
# Personal API token from https://app.clickup.com/settings/apps
CLICKUP_API_KEY=pk_...

# The list where org tasks go. Get via:
#   curl -H "Authorization: $CLICKUP_API_KEY" https://api.clickup.com/api/v2/team
#   curl -H "Authorization: $CLICKUP_API_KEY" https://api.clickup.com/api/v2/team/{team_id}/space
#   curl -H "Authorization: $CLICKUP_API_KEY" https://api.clickup.com/api/v2/space/{space_id}/list
CLICKUP_LIST_ID=

# --- Anthropic ---
# Leave EMPTY if running on Claude Max subscription via Claude Code (preferred).
# Set only if you want to use API billing instead, AND set CLAUDE_RUNTIME=api.
ANTHROPIC_API_KEY=

# Runtime: "code" uses Claude Code headless (Max subscription billing).
#          "api"  uses claude-agent-sdk (API billing). Requires ANTHROPIC_API_KEY.
CLAUDE_RUNTIME=code

# --- Bridge config ---
# How many recent exchanges per channel to keep in memory and replay to each agent.
# Higher = better continuity but more tokens per turn. 6 is a good middle.
CHAT_HISTORY_TURNS=6

# Log level: DEBUG, INFO, WARNING
LOG_LEVEL=INFO
